# Supabase (Project Settings -> API)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Paystack (Dashboard -> Settings -> API Keys & Webhooks)
PAYSTACK_SECRET_KEY=   # used server-side to initialise + verify + sign-check
PAYSTACK_PUBLIC_KEY=   # used in the Liquid section (front-end), documented here for reference

# Comma-separated storefront origins allowed to call /availability and /checkout
ALLOWED_ORIGINS=https://25pskyn.com,https://www.25pskyn.com

# Optional: protects the /api/cron/release endpoint
CRON_SECRET=
